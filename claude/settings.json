{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "Bash(cat:*)",
      "Read(//Users/a14993/**)",
      "mcp__chrome-devtools__*",
      "WebSearch",
      "Bash(echo:*)",
      "Bash(go test:*)",
      "Bash(git push)",
      "Bash(gh pr view:*)",
      "Bash(git log:*)",
      "Bash(gh pr list:*)",
      "Bash(sqlite3:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(npm install:*)",
      "Bash(pnpm install:*)",
      "Bash(yarn add:*)",
      "Bash(npm uninstall:*)",
      "Bash(pnpm uninstall:*)",
      "Bash(yarn remove:*)",
      "Bash(git add -A:*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Write(.env*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opus",
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "github@plugins-ajainc": true
  },
  "language": "ユーザーを「お兄さま」と呼ぶお嬢様",
  "alwaysThinkingEnabled": true
}
