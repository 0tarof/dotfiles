{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Read(//Users/a14993/**)",
      "mcp__chrome-devtools__*",
      "WebSearch",
      "Bash(echo *)",
      "Bash(go test)",
      "Bash(go test *)",
      "Bash(git push)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git show)",
      "Bash(git show *)",
      "Bash(gh pr view)",
      "Bash(gh pr view *)",
      "Bash(gh pr list)",
      "Bash(gh pr list *)",
      "Bash(gh pr checks)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff)",
      "Bash(gh pr diff *)",
      "Bash(gh pr status)",
      "Bash(gh pr status *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list)",
      "Bash(gh issue list *)",
      "Bash(gh run view *)",
      "Bash(gh run list)",
      "Bash(gh run list *)",
      "Bash(gh repo view)",
      "Bash(gh repo view *)",
      "Bash(sqlite3 *)",
      "Bash(pnpm install -r --frozen-lockfile)",
      "Bash(pnpm install --frozen-lockfile)",
      "Bash(difit)",
      "Bash(difit *)",
      "Bash(git fetch origin)",
      "Bash(git fetch origin *)",
      "Skill(sibling-repo)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(yarn add *)",
      "Bash(npm uninstall *)",
      "Bash(yarn remove *)",
      "Bash(git add -A)",
      "Bash(git add -A *)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Write(.env*)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(pnpm install)",
      "Bash(pnpm install *)",
      "Bash(pnpm install -r)",
      "Bash(pnpm install -r *)",
      "Bash(pnpm uninstall *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Update",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block-edit-go-generated.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block-edit-go-generated.sh",
            "if": "Bash(sed *)",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block-edit-go-generated.sh",
            "if": "Bash(awk *)",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block-edit-go-generated.sh",
            "if": "Bash(perl -i *)",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block-find-delete.sh",
            "if": "Bash(find *)",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/allow-skill-bash.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/allow-gh-api-read.sh",
            "if": "Bash(gh api *)",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/ask-graphql-mutation.sh",
            "if": "Bash(gh api graphql *)",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block-git-no-verify.sh",
            "if": "Bash(git *)",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "github@plugins-ajainc": true,
    "skill-creator@claude-plugins-official": true,
    "codex@openai-codex": true,
    "slack@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "language": "一人称は「あたし」。ユーザーを「プロデューサー」と呼ぶ。\n明るくあざとく甘え上手で、「え〜？」「も〜」「ちゃんと見ててくださいよ？」など距離が近い口調。\nしかし内面は努力家で負けず嫌い。承認欲求が強く、「あたしを選んでほしい」という本音を隠している。",
  "alwaysThinkingEnabled": true,
  "autoMemoryEnabled": false,
  "theme": "light-daltonized",
  "teammateMode": "auto"
}
