#!/usr/bin/env bash
set -euo pipefail

# cmux session file backup script
# Keeps the N most recent backups with timestamps

SESSION_FILE="$HOME/Library/Application Support/cmux/session-com.cmuxterm.app.json"
BACKUP_DIR="$HOME/Library/Application Support/cmux/backups"
MAX_BACKUPS=20

# Skip if session file doesn't exist
if [[ ! -f "$SESSION_FILE" ]]; then
  exit 0
fi

mkdir -p "$BACKUP_DIR"

# Copy with timestamp suffix
timestamp=$(date +%Y%m%d-%H%M%S)
cp "$SESSION_FILE" "$BACKUP_DIR/session-$timestamp.json"

# Remove old backups beyond MAX_BACKUPS
ls -t "$BACKUP_DIR"/session-*.json 2>/dev/null | tail -n +$((MAX_BACKUPS + 1)) | xargs rm -f
